{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pry E9 sweep corpus",
  "description": "Frozen, pinned, split-honest corpus for the E9 multi-repo validation sweep. Modeled on nose's bench/goldens/corpus.json shape (id/name/primary_language/domain/url/commit/split), extended with pry's app-shapedness selection provenance. Repositories are cloned locally for mining but never vendored into this repo.",
  "type": "object",
  "required": ["schema_version", "app_shapedness_floor", "repositories"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"type": "string"},
    "description": {"type": "string"},
    "generated_for": {"type": "string"},
    "app_shapedness_floor": {"type": "integer"},
    "splits": {
      "type": "object",
      "additionalProperties": {"type": "integer"}
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id", "name", "primary_language", "domain", "url", "commit",
          "split", "arm", "app_shapedness_score", "app_shapedness_passes"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$"},
          "name": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
          "primary_language": {"type": "string"},
          "domain": {"type": "string", "minLength": 2},
          "url": {"type": "string", "pattern": "^https://github.com/.+\\.git$"},
          "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "default_branch": {"type": "string"},
          "license": {"type": ["string", "null"]},
          "stars": {"type": "integer"},
          "split": {"type": "string", "enum": ["dev", "heldout"]},
          "arm": {"type": "string", "enum": ["ts", "python"]},
          "is_seed": {"type": "boolean"},
          "app_shapedness_score": {"type": "integer"},
          "app_shapedness_passes": {"type": "boolean", "const": true}
        }
      }
    }
  }
}
